# -----------------------------------------------------------------------------
# WhiteBoardAgent — backend environment
# Copy to `.env` in this directory (`backend/.env`) and fill in values.
# `app/main.py` loads `backend/.env` on startup (see `app/env_loader.py`).
# -----------------------------------------------------------------------------

# =============================================================================
# OpenAI (vision + chat completions + tool agent)
# =============================================================================

# Provider: set to "openai" to force API calls. If unset and OPENAI_API_KEY is set,
# behavior is OpenAI; if the key is missing, the app uses "mock" responses.
REASONING_PROVIDER=openai

# Required for non-mock reasoning. Leave empty only for offline / tests.
OPENAI_API_KEY=

# Model id (Responses / Chat Completions).
OPENAI_MODEL=gpt-4o

# HTTP timeout for OpenAI (seconds).
# Note: `app/services/reasoner.py` defaults to 60 if unset; `reasoner_agent.py`
# defaults to 90 if unset. Setting this variable aligns both paths.
OPENAI_TIMEOUT_SECONDS=90

# =============================================================================
# Web search (`web_search` tool — Brave + ddgs)
# =============================================================================

# Optional. When set, Brave Search is tried first.
# https://api.search.brave.com/
BRAVE_API_KEY=

# ddgs text search timeout (seconds), clamped 5–25 in code. Default 15.
DDGS_TIMEOUT=15

# Comma-separated backends for ddgs text search. Default in code:
# yahoo,google,mojeek,duckduckgo
DDGS_TEXT_BACKEND=yahoo,google,mojeek,duckduckgo

# Optional outbound proxy for ddgs (if your network requires it).
# DDGS_PROXY=http://host:port

# =============================================================================
# Tool agent (`POST /api/v1/reason/stream` when REASONER_STREAM_AGENT=1)
# =============================================================================

# Maximum tool-capable LLM rounds before the final JSON-only answer (1–12). Default 4.
REASONER_AGENT_MAX_ROUNDS=4

# Wall-clock seconds budget for the whole tool-agent loop. Default 15.
REASONER_AGENT_BUDGET_S=15.0

# If the model hedges (e.g. "I don't know") without web_search/fetch_url, inject
# this many follow-up nudges (0–3). Default 1.
REASONER_AGENT_UNCERTAINTY_NUDGES=1

# "1" = streaming path uses the tool-capable agent when provider is OpenAI.
# "0" = use `generate_reasoning_text` only (no tools / no uncertainty nudge).
REASONER_STREAM_AGENT=1

# =============================================================================
# Agent filesystem sandbox (read_file / grep_repo / list_dir / local PDF index)
# =============================================================================

# Absolute directory root for those tools. If unset, defaults to `backend/data`
# next to the package (see `app/services/tools/sandbox_config.py`).
# AGENT_CODE_TOOLS_SCOPE=
